        <cost name="Combined Warlord and Lord of War Points" typeId="14bd-cad0-cd3d-8b23" value="0"/>
        <cost name="Mech LB" typeId="7275-cbe8-a563-7152" value="0"/>
        <cost name="Asset Point(s)" typeId="29b4-fb27-da17-1e21" value="2"/>
      </costs>
      <profiles>
        <profile name="Wayfinder Device" typeId="7ae0-de68-04c6-8d8f" typeName="Asset" hidden="false" id="c4c7-d41f-c118-d2c4">
          <characteristics>
            <characteristic name="Summary" typeId="3dcf-9034-fc2d-cd56">A Wayfinder Device can grant nearby Models the Move Through Cover Special Rule.</characteristic>
            <characteristic name="Setup" typeId="e965-60bc-cd79-63e7">Each Wayfinder Device Marker must be set up by the Player that selected it at the start of the Deploy Armies Step. It must be set up with the centre of the Marker anywhere on the Battlefield that is not within their Opponent&apos;s Deployment Zone.</characteristic>
            <characteristic name="Effect" typeId="bbd3-5482-ed3a-a3b3">In the Effects Sub-Phase of their Player Turn, the Player who set up a Wayfinder Device can select to trigger it. If they do, they can select one Area of Difficult or Dangerous Terrain that is wholly within 12&quot; of the centre of that Wayfinder Device Marker. Models from that Player&apos;s Army are treated as having the Move Through Cover Special Rule while moving through the selected Area Terrain during that Turn.</characteristic>
            <characteristic name="How To Destroy" typeId="6888-e488-df3f-edcf">N/A</characteristic>
            <characteristic name="Traits" typeId="a1e3-4f30-fa22-d127">Attacker</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="set" value="true" field="hidden">
          <conditions>
            <condition type="atLeast" value="1" field="selections" scope="roster" childId="81e6-a6ec-25e5-68ff" shared="true" childName="Defender" includeChildSelections="true" includeChildForces="true"/>
          </conditions>
          <comment>Hidden From Defenders</comment>
        </modifier>
      </modifiers>
