    <selectionEntry type="upgrade" import="true" name="Infernus incinerator" hidden="false" id="e847-50cf-f96a-5950">
      <profiles>
        <profile name="Infernus incinerator" typeId="c591-09ed-3e6f-eb2b" typeName="Ranged Weapon" hidden="false" id="cbd1-beba-e49a-249a">
