  <sharedSelectionEntryGroups>
    <selectionEntryGroup name="Prime Benefits" id="6f4b-388a-b001-abde" hidden="false">
      <entryLinks>
        <entryLink import="true" name="Common Prime Benefits" hidden="false" id="3b2f-a759-71a1-98c0" type="selectionEntryGroup" targetId="93f7-d7db-d7f0-2146"/>
        <entryLink import="true" name="Armoured Spearhead Prime Traits" hidden="true" id="9475-e238-cb1d-0c21" type="selectionEntryGroup" targetId="79f0-9479-4fe9-b4d6"/>
      </entryLinks>
      <selectionEntryGroups>
        <selectionEntryGroup name="Custodes Prime Benefits" id="1c4b-a6df-2887-d5e3" hidden="false">
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Prefect" hidden="true" id="43e4-8335-e000-62a6">
              <modifiers>
                <modifier type="set" value="false" field="hidden">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="unit" childId="ead9-2ff9-9301-8c60" shared="true"/>
                  </conditions>
                </modifier>
                <modifier type="add" value="901a-6b71-7a29-4597" field="category"/>
              </modifiers>
              <rules>
                <rule name="Prefect" id="28fb-ffb2-ad9d-8596" hidden="false">
                  <description>All Models in the Unit selected to fill a Prime Slot with thisd Prime Advantage modify their Base Wounds Characteristic by +1 and gain the Officer of the Line (2) Special Rule</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink name="Officer of the Line (X)" id="973a-a578-119a-c6b7" hidden="false" type="rule" targetId="7779-47c8-99a8-b935">
                  <comment>2</comment>
                  <modifiers>
                    <modifier type="replace" value="2" field="name" arg="X"/>
                  </modifiers>
                </infoLink>
              </infoLinks>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="5f41-05c5-aa58-a672"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Hetaeron Guard" hidden="true" id="680b-53b4-4f4b-551f">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="dcd5-b08d-2336-b82c" includeChildSelections="true" includeChildForces="true"/>
              </constraints>
              <modifiers>
                <modifier type="increment" value="1" field="dcd5-b08d-2336-b82c">
                  <repeats>
                    <repeat value="1" repeats="1" field="selections" scope="roster" childId="6da5-a1b8-41c0-b6fc" shared="true" roundUp="false" includeChildSelections="true" includeChildForces="true"/>
                  </repeats>
                </modifier>
                <modifier type="set" value="false" field="hidden">
                  <conditionGroups>
                    <conditionGroup type="or">
                      <conditions>
                        <condition type="atLeast" value="1" field="selections" scope="unit" childId="594d-fa82-13cb-a345" shared="true" includeChildSelections="true"/>
                        <condition type="atLeast" value="1" field="selections" scope="unit" childId="a073-2d4a-5bed-123e" shared="true" includeChildSelections="true"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
              </modifiers>
              <rules>
                <rule name="Hetaeron Guard" id="99fd-0a73-7633-8437" hidden="false">
                  <description>All Models in the Unit selected to fill a Prime Slot with this Prime Advantage which have the Legio Custodes Trait and the Infantry or Cavalry Type modify the value of X of any version of the Enetrnal Warrior (X) Special Rule they have to &apos;2&apos;. This Prime Advantage may only be selected once per Army, unless the Army contains any Models with the Golden Exemplar Trait, in which case a single additional selection of this Prime Advantage may be made for each Model in the Army with that Trait.</description>
                </rule>
              </rules>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="3f13-a9ef-3c37-dc0f"/>
      </constraints>
    </selectionEntryGroup>
    <selectionEntryGroup name="Legio Tactica" id="05d6-c214-1c60-331b" hidden="false">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Legio Tactica" hidden="false" id="6bc3-e10d-ccec-d76d" sortIndex="1">
          <rules>
            <rule name="Only in Death" id="28e4-4dfb-df30-cdee" hidden="false">
              <description>&quot;Units which only contain Models with this Special Rule become Stunned instead of Routed in Combat and cannot Fall Back or Disengage from a Combat.&quot;


Whenever a Model with this Special Rule would gain the Routed Tactical Status in the Make Panic Checks Step of the Resolution Sub-Phase of the Assault Phase, that Model instead gains the Stunned Tactical Status, unless there are any Models without this Special Rule in the same Unit as that Model. Additionally, a Unit which only contains Models with this Special Rule may never have the Disengage or Fall Back aftermath options selected for it, unless it is entirely composed of Models which also have the Antigrav Sub-Type, in which case it may still have the Disengage aftermath option selected for it.</description>
            </rule>
          </rules>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="cc1d-d3c5-bbd6-e802"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="f4a7-85f7-ba60-bd0b"/>
          </constraints>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Gambits" hidden="false" id="a986-2fd8-5d69-16db" sortIndex="2">
          <infoLinks>
            <infoLink name="Heaven&apos;s Strike" id="144b-549d-7c06-777c" hidden="false" type="profile" targetId="e420-6f61-30cb-98b0"/>
            <infoLink name="Raptor&apos;s Surge" id="a55a-a10b-d145-d191" hidden="false" type="profile" targetId="f484-f6c7-0361-fed0"/>
            <infoLink name="Stone&apos;s Aegis" id="a5bf-9f6b-6e36-c4b2" hidden="false" type="profile" targetId="d7a4-c4a2-dbfc-0f54"/>
            <infoLink name="World Serpent&apos;s Bane" id="adfa-b81e-adb2-362e" hidden="false" type="profile" targetId="49cc-971f-80f7-e46f"/>
          </infoLinks>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="4ef7-38af-bba9-0692"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="5bbb-ecf5-9260-bb62"/>
          </constraints>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Advanced Reaction" hidden="false" id="1ddb-a139-4402-a101" sortIndex="3">
